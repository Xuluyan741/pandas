# ─── NextAuth ────────────────────────────────────────────────────────
# 生成：openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth（可选，若不填则隐藏 Google 登录按钮）────────────────
# 申请：https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── 控制 Google 登录按钮显示（填写上方 Client ID 后改为 true）────────
NEXT_PUBLIC_GOOGLE_ENABLED=false

# ─── Turso 数据库（可选；不填则使用本地 data/app.db）────────────────────
# 生产部署必填。创建：turso db create <name> --location hkg && turso db tokens create <name>
# TURSO_DATABASE_URL=libsql://your-db-xxx.turso.io
# TURSO_AUTH_TOKEN=

# ─── 每日推送（Web Push）──────────────────────────────────────────────
# 生成 VAPID 密钥：npx web-push generate-vapid-keys
# 公钥放 NEXT_PUBLIC_，私钥放 VAPID_PRIVATE_KEY（不要泄露）
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ─── DeepSeek 文本解析（AI 任务拆解）───────────────────────────────────
# 在 https://platform.deepseek.com/api_keys 申请 API Key
# 用于 /api/ai/parse-tasks 接口，将自然语言日程解析为任务列表
# DEEPSEEK_API_KEY=your-deepseek-api-key
# 可选：自定义模型（默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat
# 可选：自定义 DeepSeek API 基础地址（默认官方）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── OpenAI / gptsapi 语音转文字（可选）────────────────────────────────
# 若需要云端语音识别，可配置 OPENAI_BASE_URL / OPENAI_API_KEY：
# 比如使用 gptsapi:
# OPENAI_BASE_URL=https://api.gptsapi.net
# OPENAI_API_KEY=your-gptsapi-api-key
# OPENAI_TRANSCRIBE_MODEL=whisper-1

# ─── Anthropic (Claude) — 用于冲突消解、深度推理 ─────────────────────
# 申请：https://console.anthropic.com
# ANTHROPIC_API_KEY=

# ─── Google Gemini — 用于意图分类(Flash)、语音流式 ──────────────────────
# 申请：https://aistudio.google.com/apikey
# GOOGLE_API_KEY=

# ─── 多模型（nanobot 风格）────────────────────────────────────────────
# 配置任一项后，对话/解析将走意图路由（见 src/lib/ai）。仅配 DEEPSEEK 时保持单模型直连
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ─── MCP（Model Context Protocol）────────────────────────────────────
# MCP_SERVER_URL=https://your-mcp-server.com
# MCP_SERVER_HEADERS={"Authorization":"Bearer xxx"}

# ─── ClawHub 技能市场（PRD 第十一章）────────────────────────────────────
# 不填或填 https://clawhub.ai 时启用：语义搜索、按 slug 安装、即用即删（仅当轮注入，省 token）
# 设为 0 可关闭 ClawHub 对接
# CLAWHUB_API_BASE=https://clawhub.ai

# ─── Serper / Brave 搜索（长期目标资料 + web_search 技能）──────────────
# SERPER_API_KEY=
# BRAVE_API_KEY=

# ─── Agent 工作区与安全（nanobot restrictToWorkspace）──────────────────
# AGENT_WORKSPACE_DIR=data/workspace
# AGENT_RESTRICT_TO_WORKSPACE=true
# AGENT_SHELL_ENABLED=false

# ─── Telegram 通道 ───────────────────────────────────────────────────
# 在 @BotFather 创建 Bot 后设置 webhook: https://your-domain/api/channels/telegram/webhook
# TELEGRAM_BOT_TOKEN=

# ─── vLLM 本地/自建模型 ───────────────────────────────────────────────
# VLLM_API_BASE=http://localhost:8000/v1
# VLLM_API_KEY=dummy
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ─── 定时任务密钥（保护 /api/cron/*）──────────────────────────────────
# 生成：openssl rand -base64 24。Vercel Cron 会带此值调用接口
# CRON_SECRET=

# ─── Stripe 支付（Pro 订阅）────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com → API Keys / Products / Webhooks
# STRIPE_SECRET_KEY=sk_xxx
# STRIPE_PRICE_ID_MONTHLY=price_xxx   （月付 Price ID）
# STRIPE_PRICE_ID_YEARLY=price_xxx    （年付 Price ID）
# STRIPE_WEBHOOK_SECRET=whsec_xxx     （Webhook 签名密钥，Endpoint 填 /api/stripe/webhook）
