# ─── NextAuth ────────────────────────────────────────────────────────
# 生成：openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth（可选，若不填则隐藏 Google 登录按钮）────────────────
# 申请：https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── 控制 Google 登录按钮显示（填写上方 Client ID 后改为 true）────────
NEXT_PUBLIC_GOOGLE_ENABLED=false

# ─── Turso 数据库（可选；不填则使用本地 data/app.db）────────────────────
# 生产部署必填。创建：turso db create <name> --location hkg && turso db tokens create <name>
# TURSO_DATABASE_URL=libsql://your-db-xxx.turso.io
# TURSO_AUTH_TOKEN=

# ─── 每日推送（Web Push）──────────────────────────────────────────────
# 生成 VAPID 密钥：npx web-push generate-vapid-keys
# 公钥放 NEXT_PUBLIC_，私钥放 VAPID_PRIVATE_KEY（不要泄露）
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ─── 定时任务密钥（保护 /api/cron/daily-push）────────────────────────
# 生成：openssl rand -base64 24。Vercel Cron 会带此值调用接口
# CRON_SECRET=
